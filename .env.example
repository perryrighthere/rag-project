# Application
APP_NAME=rag-project
APP_ENV=local
API_PREFIX=
APP_PORT=8000

# Infrastructure
# Docker Compose local dependencies are configured by docker-compose.local.yml.
# Leave these unset for the default local Compose stack.
#
# For local Python without Docker Compose:
# DATABASE_URL=sqlite+pysqlite:///./rag_project.db
# MILVUS_URI=http://127.0.0.1:19530
# MINIO_ENDPOINT=localhost:9000
#
# For Docker Compose app-only mode with external services on the host:
# DATABASE_URL=postgresql+psycopg://rag:rag@host.docker.internal:5432/rag
# MILVUS_URI=http://host.docker.internal:19530
# MINIO_ENDPOINT=host.docker.internal:9000
#
# Optional host port overrides for docker-compose.local.yml:
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-project
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# MinerU API
# Docker containers should use host.docker.internal to call a MinerU service running on the host.
MINERU_BASE_URL=http://host.docker.internal:18000
MINERU_BACKEND=pipeline
MINERU_PARSE_METHOD=auto
MINERU_LANG_LIST='["ch"]'
MINERU_REQUEST_TIMEOUT=60
MINERU_POLL_INTERVAL_SECONDS=2
MINERU_MAX_WAIT_SECONDS=600

# Optional VLM image explanations
VLM_IMAGE_EXPLANATIONS_ENABLED=false
VLM_BASE_URL=
VLM_API_KEY=EMPTY
VLM_MODEL=
VLM_PROMPT=
VLM_TIMEOUT=120
VLM_MAX_TOKENS=300

# Embedding API, OpenAI-compatible
EMBEDDING_BASE_URL=https://your-openai-compatible-provider.example.com/v1
EMBEDDING_API_KEY=your-api-key
EMBEDDING_MODEL=text-embedding-model
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT=60

# Milvus
# MILVUS_URI is provided by docker-compose.local.yml for the default local stack.
MILVUS_COLLECTION=rag_chunks

# Optional rerank API, OpenAI-compatible
RERANK_BASE_URL=
RERANK_API_KEY=EMPTY
RERANK_MODEL=
RERANK_TIMEOUT=60

# Chat API, OpenAI-compatible
CHAT_BASE_URL=https://your-openai-compatible-provider.example.com/v1
CHAT_API_KEY=your-api-key
CHAT_MODEL=chat-model
CHAT_TIMEOUT=60
CHAT_TEMPERATURE=0.2
CHAT_MAX_TOKENS=1200

# QA orchestration
# single keeps the existing direct answer-generation behavior.
# langgraph_multi uses the built-in multi-agent workflow without optional dependencies.
# crewai and autogen require installing requirements-agentic.txt.
QA_ORCHESTRATOR=single
QA_AGENT_MAX_ROUNDS=3
